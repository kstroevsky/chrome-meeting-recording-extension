{
  "manifest_version": 3,
  "name": "Google Meet Transcript + Recorder",
  "version": "1.1.0",
  "key": "",
  "permissions": [
    "activeTab",
    "downloads",
    "tabCapture",
    "offscreen",
    "storage",
    "tabs",
    "desktopCapture",
    "identity"
  ],
  "oauth2": {
    "client_id": "908748525392-0mjfkrpc11tvssqjg7mlsbf621f51eq4.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file"
    ]
  },
  "host_permissions": [
    "https://meet.google.com/*",
    "https://www.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*"
      ],
      "js": [
        "scrapingScript.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
