{
    "name": "google-meet-caption-extension",
    "version": "1.0.0",
    "scripts": {
        "dev": "webpack --mode=development",
        "build": "webpack --mode=production",
        "build:e2e:mock": "webpack --mode=development --env e2eMockCapture=1 --env outputPath=dist-e2e",
        "watch": "webpack --mode=development --watch",
        "test": "npm run test:unit",
        "test:unit": "jest --runInBand --watchman=false --testPathIgnorePatterns=/tests/e2e/",
        "test:e2e": "npm run test:e2e:mock",
        "test:e2e:mock": "npm run build:e2e:mock && playwright test --config=playwright.config.ts",
        "test:e2e:live": "npm run test:real-meet",
        "test:real-meet": "node scripts/validate-real-meet.mjs",
        "typecheck": "tsc --noEmit",
        "lint": "npm run typecheck"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@types/chrome": "^0.0.326",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.0.4",
        "@types/puppeteer": "^5.4.7",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^13.0.1",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "playwright": "^1.60.0",
        "puppeteer": "^24.38.0",
        "puppeteer-core": "^24.38.0",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.0",
        "typescript": "^5.8.3",
        "webpack": "^5.99.9",
        "webpack-cli": "^6.0.1"
    },
    "main": "webpack.config.js",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "fix-webm-duration": "^1.0.6"
    }
}
