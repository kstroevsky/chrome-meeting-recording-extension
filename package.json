{
    "name": "google-meet-caption-extension",
    "version": "1.0.0",
    "scripts": {
        "dev": "webpack --mode=development",
        "build": "webpack --mode=production",
        "build:e2e:mock": "webpack --mode=development --env e2eMockCapture=1 --env e2eMockDrive=1 --env outputPath=dist-e2e",
        "watch": "webpack --mode=development --watch",
        "test": "npm run test:unit",
        "test:unit": "npm run test:unit:jest && npm run test:unit:node",
        "test:unit:jest": "jest --runInBand --watchman=false --testPathIgnorePatterns=/tests/e2e/",
        "test:unit:node": "node --test tests/scripts/*.test.mjs",
        "test:e2e": "npm run test:e2e:mock",
        "test:e2e:mock": "npm run build:e2e:mock && playwright test --config=playwright.config.ts --grep-invert \"@perf-(full|endurance|hardware)\"",
        "test:e2e:perf:smoke": "npm run build:e2e:mock && playwright test --config=playwright.config.ts --grep \"@perf-smoke\"",
        "test:e2e:perf:full": "npm run build:e2e:mock && playwright test --config=playwright.config.ts --grep \"@perf-(smoke|full)\"",
        "test:e2e:perf:endurance": "npm run build:e2e:mock && playwright test --config=playwright.config.ts --grep \"@perf-endurance\"",
        "test:e2e:perf:hardware": "npm run build:e2e:mock && PW_REAL_MEDIA=1 PW_HEADLESS=0 playwright test --config=playwright.config.ts --grep \"@perf-hardware\"",
        "test:e2e:perf": "npm run test:e2e:perf:full",
        "test:e2e:real:profile": "node scripts/setup-real-meet-profile.mjs",
        "test:e2e:real": "node scripts/run-real-meet-e2e.mjs",
        "test:e2e:live": "node scripts/run-real-meet-e2e.mjs",
        "test:real-meet": "node scripts/run-real-meet-e2e.mjs",
        "typecheck": "tsc --noEmit",
        "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
        "test:production-guards": "node scripts/check-production-build.mjs",
        "lint": "npm run typecheck"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@types/chrome": "^0.0.326",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.0.4",
        "@types/puppeteer": "^5.4.7",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^13.0.1",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "playwright": "^1.60.0",
        "puppeteer": "^24.38.0",
        "puppeteer-core": "^24.38.0",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.0",
        "typescript": "^5.8.3",
        "webpack": "^5.99.9",
        "webpack-cli": "^6.0.1"
    },
    "main": "webpack.config.js",
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "webm-duration-fix": "^1.0.4"
    }
}
